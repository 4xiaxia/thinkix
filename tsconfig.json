{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/features/*": ["./features/*"],
      "@/shared/*": ["./shared/*"],
      "@thinkix/ui": ["./packages/ui/src"],
      "@thinkix/ai": ["./packages/ai/lib"],
      "@thinkix/plait-utils": ["./packages/plait-utils/lib"],
      "@thinkix/storage": ["./packages/storage/lib"],
      "@thinkix/shared": ["./packages/shared/src"],
      "@thinkix/file-utils": ["./packages/file-utils/src"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scratch",
    "tests",
    "coverage"
  ]
}
