{
  "name": "thinkix",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "bash scripts/apply-patches.sh",
    "build": "bunx next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage && bun scripts/coverage-summary.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "bun run test:run && bun run test:e2e",
    "postinstall": "bash scripts/apply-patches.sh"
    },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "@ai-sdk/react": "^1.1.0",
    "@floating-ui/react": "^0.27.17",
    "@liveblocks/node": "3.14.1",
    "@plait-board/react-board": "0.4.0-2",
    "@plait-board/react-text": "^0.4.0-0",
    "@plait/common": "^0.92.1",
    "@plait/core": "^0.92.1",
    "@plait/draw": "0.92.3",
    "@plait/layouts": "0.92.3",
    "@plait/mind": "^0.92.1",
    "@plait/text": "^0.60.4",
    "@radix-ui/react-slider": "^1.3.6",
    "ai": "^4.0.0",
    "browser-fs-access": "^0.38.0",
    "dexie": "^4.3.0",
    "idb": "^8.0.0",
    "immer": "^10.0.4",
    "is-hotkey": "^0.2.0",
    "laser-pen": "^1.0.1",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "posthog-js": "1.356.1",
    "posthog-node": "5.26.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "roughjs": "^4.6.6",
    "slate": "^0.116.0",
    "slate-dom": "^0.116.0",
    "slate-history": "^0.115.0",
